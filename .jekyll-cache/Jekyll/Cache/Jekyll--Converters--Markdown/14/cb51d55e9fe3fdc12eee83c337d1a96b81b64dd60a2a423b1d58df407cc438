<div class="language-html highlighter-rouge"><div class="highlight"><pre class="highlight"><code><span class="nt">&lt;form</span> <span class="na">action=</span><span class="s">"select.php"</span> <span class="na">method=</span><span class="s">"get"</span><span class="nt">&gt;</span>
