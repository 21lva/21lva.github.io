<h1 id="к°қмІҙ-мЎ°мһ‘">к°қмІҙ мЎ°мһ‘</h1>

<ul>
  <li>к°қмІҙлҘј мЎ°мһ‘н•ҳлҠ” л°©лІ•м—җлҠ”
    <ol>
      <li>мғқм„ұ</li>
      <li>ліөм ң</li>
      <li>мӮӯм ң</li>
      <li>мҶҚм„ұ ліҖкІҪ
л“ұмқҙ мһҲлӢӨ.</li>
    </ol>
  </li>
</ul>

<h2 id="1-мҶҚм„ұ-л©”м„ңл“ң">1) мҶҚм„ұ л©”м„ңл“ң</h2>

<div class="language-js highlighter-rouge"><div class="highlight"><pre class="highlight"><code><span class="c1">//html() : м„ нғқн•ң мҡ”мҶҢмқҳ н•ҳмң„ мҡ”мҶҢлҘј к°Җм ёмҷҖ л¬ёмһҗм—ҙлЎң ліҖнҷҳ or м „л¶Җ м ңкұ° нӣ„ ліҖкІҪ</span>
<span class="nx">$</span><span class="p">(</span><span class="dl">"</span><span class="s2">мҡ”мҶҢ</span><span class="dl">"</span><span class="p">).</span><span class="nx">html</span><span class="p">();</span>
<span class="nx">$</span><span class="p">(</span><span class="dl">"</span><span class="s2">мҡ”мҶҢ</span><span class="dl">"</span><span class="p">).</span><span class="nx">html</span><span class="p">(</span><span class="dl">"</span><span class="s2">мғҲ мҡ”мҶҢ</span><span class="dl">"</span><span class="p">);</span>

<span class="c1">//text() : м„ нғқн•ң мҡ”мҶҢм—җ нҸ¬н•Ёлҗҳм–ҙ мһҲлҠ” м „мІҙ н…ҚмҠӨнҠёлҘј к°Җм ёмҳӨкё° or м „л¶Җ м ңкұ° нӣ„ ліҖкІҪ</span>
<span class="nx">$</span><span class="p">(</span><span class="dl">"</span><span class="s2">мҡ”мҶҢ</span><span class="dl">"</span><span class="p">).</span><span class="nx">text</span><span class="p">();</span>
<span class="nx">$</span><span class="p">(</span><span class="dl">"</span><span class="s2">мҡ”мҶҢ</span><span class="dl">"</span><span class="p">).</span><span class="nx">text</span><span class="p">(</span><span class="dl">"</span><span class="s2">мғҲ н…ҚмҠӨнҠё</span><span class="dl">"</span><span class="p">);</span>

<span class="c1">//attr() : м„ нғқн•ң мҡ”мҶҢмқҳ  мҶҚм„ұк°’мқ„ к°Җм ёмҳЁлӢӨ or мҶҚм„ұк°’мқ„ ліҖкІҪ</span>
<span class="nx">$</span><span class="p">(</span><span class="dl">"</span><span class="s2">мҡ”мҶҢ</span><span class="dl">"</span><span class="p">).</span><span class="nx">attr</span><span class="p">(</span><span class="dl">"</span><span class="s2">мҶҚм„ұ</span><span class="dl">"</span><span class="p">);</span>
<span class="nx">$</span><span class="p">(</span><span class="dl">"</span><span class="s2">мҡ”мҶҢ</span><span class="dl">"</span><span class="p">).</span><span class="nx">attr</span><span class="p">(</span><span class="dl">"</span><span class="s2">мҶҚм„ұ</span><span class="dl">"</span><span class="p">,</span><span class="dl">"</span><span class="s2">мғҲ к°’</span><span class="dl">"</span><span class="p">);</span>
<span class="nx">$</span><span class="p">(</span><span class="dl">"</span><span class="s2">мҡ”мҶҢ</span><span class="dl">"</span><span class="p">).</span><span class="nx">attr</span><span class="p">(</span><span class="dl">"</span><span class="s2">мҶҚм„ұ1</span><span class="dl">"</span><span class="p">:</span><span class="dl">"</span><span class="s2">мғҲ к°’1</span><span class="dl">"</span><span class="p">,</span><span class="dl">"</span><span class="s2">мҶҚм„ұ2</span><span class="dl">"</span><span class="p">,</span><span class="dl">"</span><span class="s2">мғҲ к°’2</span><span class="dl">"</span><span class="p">);</span>

<span class="c1">//removeAttr() : мҶҚм„ұ м ңкұ°</span>
<span class="nx">$</span><span class="p">(</span><span class="dl">"</span><span class="s2">мҡ”мҶҢ</span><span class="dl">"</span><span class="p">).</span><span class="nx">removeAttr</span><span class="p">(</span><span class="dl">"</span><span class="s2">мҶҚм„ұ</span><span class="dl">"</span><span class="p">);</span>

<span class="c1">//addClass() / removeClass() / toggleClass() / hasClass() : м„ нғқн•ң мҡ”мҶҢм—җ нҒҙлһҳмҠӨ мғқм„ұ/ м ңкұ°/ м—Ҷмңјл©ҙ мғқм„ұorмһҲмңјл©ҙ м ңкұ°/ мһҲлҠ”м§Җ нҷ•мқё</span>
<span class="nx">$</span><span class="p">(</span><span class="dl">"</span><span class="s2">мҡ”мҶҢ</span><span class="dl">"</span><span class="p">).</span><span class="nx">addClass</span><span class="p">(</span><span class="dl">"</span><span class="s2">нҒҙлһҳмҠӨ к°’</span><span class="dl">"</span><span class="p">)</span>
<span class="nx">$</span><span class="p">(</span><span class="dl">"</span><span class="s2">мҡ”мҶҢ</span><span class="dl">"</span><span class="p">).</span><span class="nx">removeClass</span><span class="p">(</span><span class="dl">"</span><span class="s2">нҒҙлһҳмҠӨ к°’</span><span class="dl">"</span><span class="p">)</span>
<span class="nx">$</span><span class="p">(</span><span class="dl">"</span><span class="s2">мҡ”мҶҢ</span><span class="dl">"</span><span class="p">).</span><span class="nx">toggleClass</span><span class="p">(</span><span class="dl">"</span><span class="s2">нҒҙлһҳмҠӨ к°’</span><span class="dl">"</span><span class="p">)</span>
<span class="nx">$</span><span class="p">(</span><span class="dl">"</span><span class="s2">мҡ”мҶҢ</span><span class="dl">"</span><span class="p">).</span><span class="nx">hasClass</span><span class="p">(</span><span class="dl">"</span><span class="s2">нҒҙлһҳмҠӨ к°’</span><span class="dl">"</span><span class="p">)</span>

<span class="c1">//val() : мҡ”мҶҢмқҳ valueк°’мқ„ к°Җм ёмҳӨкұ°лӮҳ ліҖкІҪ</span>
<span class="nx">$</span><span class="p">(</span><span class="dl">"</span><span class="s2">мҡ”мҶҢ</span><span class="dl">"</span><span class="p">).</span><span class="nx">val</span><span class="p">();</span>
<span class="nx">$</span><span class="p">(</span><span class="dl">"</span><span class="s2">мҡ”мҶҢ</span><span class="dl">"</span><span class="p">).</span><span class="nx">val</span><span class="p">(</span><span class="dl">"</span><span class="s2">мғҲ к°’</span><span class="dl">"</span><span class="p">);</span>

<span class="c1">//prop() : м„ нғқн•ң нҸј мҡ”мҶҢмқҳ мғҒнғң мҶҚм„ұк°’мқ„ к°Җм ёмҳӨкұ°лӮҳ мғҲлЎӯкІҢ ліҖкІҪ.</span>
<span class="nx">$</span><span class="p">(</span><span class="dl">"</span><span class="s2">мҡ”мҶҢ</span><span class="dl">"</span><span class="p">).</span><span class="nx">prop</span><span class="p">(</span><span class="dl">"</span><span class="s2">checked|selected</span><span class="dl">"</span><span class="p">);</span>
</code></pre></div></div>

<h2 id="2-мҲҳм№ҳ-мЎ°мһ‘-л©”м„ңл“ң">2) мҲҳм№ҳ мЎ°мһ‘ л©”м„ңл“ң</h2>

<ul>
  <li>мҡ”мҶҢмқҳ мҶҚм„ұмқ„ мЎ°мһ‘н•  л•Ң мӮ¬мҡ©</li>
</ul>

<div class="language-js highlighter-rouge"><div class="highlight"><pre class="highlight"><code><span class="c1">//height(),width() : contentsмқҳ лҶ’мқҙ, л„Ҳл№„ ліҖкІҪ</span>
<span class="nx">$</span><span class="p">(</span><span class="dl">"</span><span class="s2">мҡ”мҶҢ</span><span class="dl">"</span><span class="p">).</span><span class="nx">height</span><span class="p">();</span>
<span class="nx">$</span><span class="p">(</span><span class="dl">"</span><span class="s2">мҡ”мҶҢ</span><span class="dl">"</span><span class="p">).</span><span class="nx">height</span><span class="p">(</span><span class="mi">100</span><span class="p">);</span>
<span class="nx">$</span><span class="p">(</span><span class="dl">"</span><span class="s2">мҡ”мҶҢ</span><span class="dl">"</span><span class="p">).</span><span class="nx">width</span><span class="p">();</span>
<span class="nx">$</span><span class="p">(</span><span class="dl">"</span><span class="s2">мҡ”мҶҢ</span><span class="dl">"</span><span class="p">).</span><span class="nx">width</span><span class="p">(</span><span class="mi">100</span><span class="p">);</span>

<span class="c1">//innerHeight(), innerWidth() : paddingмқ„ нҸ¬н•Ён•ң лҶ’мқҙ, л„Ҳл№„ ліҖкІҪ</span>
<span class="nx">$</span><span class="p">(</span><span class="dl">"</span><span class="s2">мҡ”мҶҢ</span><span class="dl">"</span><span class="p">).</span><span class="nx">innerHeight</span><span class="p">();</span>
<span class="nx">$</span><span class="p">(</span><span class="dl">"</span><span class="s2">мҡ”мҶҢ</span><span class="dl">"</span><span class="p">).</span><span class="nx">innerheight</span><span class="p">(</span><span class="mi">100</span><span class="p">);</span>
<span class="nx">$</span><span class="p">(</span><span class="dl">"</span><span class="s2">мҡ”мҶҢ</span><span class="dl">"</span><span class="p">).</span><span class="nx">innerWidth</span><span class="p">();</span>
<span class="nx">$</span><span class="p">(</span><span class="dl">"</span><span class="s2">мҡ”мҶҢ</span><span class="dl">"</span><span class="p">).</span><span class="nx">innerWidth</span><span class="p">(</span><span class="mi">100</span><span class="p">);</span>


<span class="c1">//outerHeight(), outerWidth() : marginмқ„ нҸ¬н•Ён•ң лҶ’мқҙ, л„Ҳл№„ ліҖкІҪ</span>
<span class="nx">$</span><span class="p">(</span><span class="dl">"</span><span class="s2">мҡ”мҶҢ</span><span class="dl">"</span><span class="p">).</span><span class="nx">outerHeight</span><span class="p">();</span>
<span class="nx">$</span><span class="p">(</span><span class="dl">"</span><span class="s2">мҡ”мҶҢ</span><span class="dl">"</span><span class="p">).</span><span class="nx">outerheight</span><span class="p">(</span><span class="mi">100</span><span class="p">);</span>
<span class="nx">$</span><span class="p">(</span><span class="dl">"</span><span class="s2">мҡ”мҶҢ</span><span class="dl">"</span><span class="p">).</span><span class="nx">outerWidth</span><span class="p">();</span>
